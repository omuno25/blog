---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import ArticleCard from '../../components/primitives/ArticleCard.astro';
import ChipTag from '../../components/primitives/ChipTag.astro';
import { postService } from '@services/post.service';
import { formatDisplayDate } from '@shared/utils/date';
import { buildTocFromHtml } from '@shared/utils/toc';

export async function getStaticPaths() {
  const { items } = await postService.getPosts();
  return items.map((post) => ({ params: { slug: post.slug } }));
}

const slug = Astro.params.slug as string;
const post = await postService.getPostBySlug(slug);

if (!post) throw new Error(`Post not found for slug: ${slug}`);
const formattedPostDate = formatDisplayDate(post.date);
const tocResult = buildTocFromHtml(post.content ?? '');

const { items: relatedItems } = await postService.getPosts({ categorySlug: post.category?.slug, limit: 6 });

const related = relatedItems
  .filter((item) => item.slug !== post.slug)
  .slice(0, 2)
  .map((item) => ({
    title: item.title,
    excerpt: item.excerpt,
    slug: item.slug,
    date: item.date,
    readingTime: item.readingTime,
    image: item.image ?? '',
    tags: item.tags.map((tag) => tag.slug),
    category: item.category?.slug,
  }));
---

<DashboardLayout title={`${post.title} | Astro Blog`} description={post.excerpt} rightLinks={tocResult.links}>
  <main class="prose-wrap px-4 py-10 md:px-8">
    <a class="focus-ring text-sm text-primary hover:underline" href="/">← Back home</a>
    <article class="mt-5 space-y-5">
      {post.image && <img src={post.image} alt={post.title} class="h-64 w-full rounded-xl border border-border-soft object-cover" onerror="this.style.display='none'" />}
      <h1 class="text-4xl font-extrabold leading-tight text-text">{post.title}</h1>
      <div class="flex flex-wrap items-center gap-3 text-sm text-text-muted">
        <span>{formattedPostDate}</span>
        <span>•</span>
        <span>{post.readingTime}</span>
        {post.category && (
          <>
            <span>•</span>
            <a class="focus-ring hover:text-primary" href={`/category/${post.category.slug}`}>
              {post.category.name}
            </a>
          </>
        )}
      </div>
      {post.content && <div class="post-content text-base leading-8 text-text-muted" set:html={tocResult.html} />}
    </article>

    <section class="mt-10 border-t border-border-soft pt-6">
      <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-text-muted">Tags</h2>
      <div class="flex flex-wrap gap-2">
        {post.tags.map((tag) => <ChipTag label={tag.slug} />)}
      </div>
    </section>

    <section class="mt-12">
      <h2 class="mb-4 text-2xl font-bold">Related posts</h2>
      <div class="grid gap-4 md:grid-cols-2">
        {related.map((item) => <ArticleCard post={item} compact />)}
      </div>
    </section>
  </main>
</DashboardLayout>
