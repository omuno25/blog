---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import SearchBox from '../components/primitives/SearchBox.astro';
import ArticleCard from '../components/primitives/ArticleCard.astro';
import { postService } from '@services/post.service';

const query = Astro.url.searchParams.get('q')?.toLowerCase().trim() ?? '';
const { items } = await postService.getPosts({ search: query || undefined });

const posts = items.map((post) => ({
  title: post.title,
  excerpt: post.excerpt,
  slug: post.slug,
  date: post.date,
  readingTime: post.readingTime,
  image: post.image ?? '',
  tags: post.tags.map((tag) => tag.slug),
  category: post.category?.slug,
}));
---

<DashboardLayout title="Search | Astro Blog">
  <main class="prose-wrap px-4 py-10 md:px-8">
    <h1 class="text-3xl font-extrabold text-text">Search</h1>
    <p class="mt-2 text-text-muted">Find posts by keyword, topic, or tag.</p>

    <form method="get" class="mt-5 max-w-xl">
      <SearchBox placeholder="Search articles..." />
    </form>

    <p class="mt-4 text-sm text-text-muted">{posts.length} result(s){query ? ` for "${query}"` : ''}</p>

    <div class="mt-8 grid gap-4 md:grid-cols-2">
      {posts.map((post) => <ArticleCard post={post} compact />)}
    </div>
  </main>
</DashboardLayout>
