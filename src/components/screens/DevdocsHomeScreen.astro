---
import HeroBlock from '../primitives/HeroBlock.astro';
import SectionHeader from '../primitives/SectionHeader.astro';
import ArticleCard from '../primitives/ArticleCard.astro';
import { heroData, posts } from '@lib/mock/ui-data';

interface Props {
  variant?: 'v1' | 'v2' | 'v3';
}

const { variant = 'v1' } = Astro.props;

const variantClasses: Record<string, string> = {
  v1: 'space-y-12',
  v2: 'space-y-12 [&_h1]:tracking-tight',
  v3: 'space-y-10 [&_section]:rounded-none',
};
---

<div class={`prose-wrap py-8 ${variantClasses[variant]}`}>
  <HeroBlock hero={heroData} />

  <section class="border-y border-border-soft bg-surface-low/50 py-10">
    <div class="mx-auto max-w-5xl px-4 md:px-8">
      <SectionHeader title="Featured Articles" subtitle="Deep dives into technical systems." linkLabel="All articles" />
      <div class="grid gap-4 md:grid-cols-2">
        {posts.slice(0, 4).map((post) => <ArticleCard post={post} compact />)}
      </div>
    </div>
  </section>

  <section id="implementation" class="pb-8">
    <SectionHeader title="Latest Posts" subtitle="Practical guides and implementation notes" />
    <div class="grid gap-4 md:grid-cols-2">
      {posts.map((post) => <ArticleCard post={post} />)}
    </div>
  </section>
</div>
