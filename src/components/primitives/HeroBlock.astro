---
import CtaButton from './CtaButton.astro';
import ChipTag from './ChipTag.astro';
import type { HeroData } from '@ui-types';

interface Props {
  hero: HeroData;
}

const { hero } = Astro.props;
---

<section class="space-y-6 py-5 md:py-5">
  <h1 class="max-w-3xl text-3xl font-extrabold leading-tight text-text md:text-5xl">{hero.headline}</h1>

  {hero.profile && (
    <div class="-mt-4 space-y-1">
      <div>
        <div class="flex flex-wrap items-center gap-2 text-xs text-text-muted">
          {hero.profile.email && <p class="font-mono">{hero.profile.email}</p>}
          {hero.profile.email && hero.profile.readingTime && <span>•</span>}
          {hero.profile.readingTime && <p>{hero.profile.readingTime}</p>}
        </div>
      </div>
    </div>
  )}

  <h2 class="max-w-2xl text-xl font-semibold leading-snug text-secondary">{hero.subheadline}</h2>
  <p class="max-w-3xl text-base leading-relaxed text-text-muted md:text-lg">{hero.description}</p>

  {hero.tags && hero.tags.length > 0 && (
    <div class="flex flex-wrap gap-2">
      {hero.tags.map((tag) => <ChipTag label={tag} />)}
    </div>
  )}

  <div class="flex flex-wrap gap-3">
    {hero.actions.map((action) => <CtaButton href={action.href} label={action.label} variant={action.variant} />)}
  </div>
</section>
