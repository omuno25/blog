---
import type { StatCardData } from '@ui-types';

interface Props {
  stat: StatCardData;
}

const { stat } = Astro.props;
---

<div class="dense-card p-4">
  <p class="text-xs uppercase tracking-wide text-outline">{stat.label}</p>
  <p class="mt-2 text-2xl font-bold text-text">{stat.value}</p>
  {stat.trend && <p class="mt-2 text-xs text-primary">{stat.trend}</p>}
</div>
