---
interface Props {
  href: string;
  label: string;
  variant?: 'primary' | 'secondary';
}

const { href, label, variant = 'primary' } = Astro.props;
const styles =
  variant === 'primary'
    ? 'bg-primary text-white border-primary hover:bg-primary-strong'
    : 'bg-white text-text border-border-soft hover:bg-surface-low';
---

<a href={href} class={`focus-ring inline-flex items-center gap-2 rounded-md border px-4 py-2 text-sm font-semibold transition-colors ${styles}`}>
  {label}
  {variant === 'primary' && <span class="material-symbols-outlined text-base">arrow_forward</span>}
</a>
